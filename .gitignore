# Tout ignorer par défaut
*

# Inclure uniquement les dossiers de deploy API
!deploy/
!deploy/qwen-image-api/
!deploy/qwen-image-api/**
!docs/
!docs/**
!.gitignore

# Exclure les fichiers sensibles/volumineux
deploy/**/.env
deploy/**/__pycache__/
deploy/**/*.pyc
deploy/**/logs/
deploy/**/*.pid
deploy/**/outputs/
deploy/**/.venv/
deploy/**/*.egg-info/
deploy/**/*.safetensors
deploy/**/*.bin
deploy/**/*.pt
deploy/**/*.ckpt
