IMAGE_NAME=vllm-node-tf5
CONTAINER_NAME=vllm_qwen_chat_canary_prismaquant475_sparkarena_mtp3_20260428

MODELS_DIR=/home/pablo/models
HF_CACHE_DIR=/home/pablo/.cache/huggingface
VLLM_CACHE_DIR=/home/pablo/.cache/vllm
FLASHINFER_CACHE_DIR=/home/pablo/.cache/flashinfer
TRITON_CACHE_DIR=/home/pablo/.triton

MODEL_ROOT=/models/Qwen3.6-35B-A3B-PrismaQuant-4.75bit-vllm-latest-20260423
TOKENIZER_ROOT=/models/Qwen3.6-35B-A3B-PrismaQuant-4.75bit-vllm-latest-20260423
SERVED_MODEL_NAME=qwen36a3b-prismaquant475-sparkarena-mtp3
VLLM_BIND_HOST=127.0.0.1
VLLM_PORT=18060
INTERNAL_VLLM_PORT=18061
MAX_MODEL_LEN=262144
GPU_MEMORY_UTILIZATION=0.60
MAX_NUM_BATCHED_TOKENS=32768
MAX_NUM_SEQS=4
KV_CACHE_MEMORY_BYTES=
SCHEDULING_POLICY=priority
KV_CACHE_DTYPE=fp8
ASYNC_SCHEDULING=0
ATTENTION_BACKEND=flashinfer
REASONING_PARSER=qwen3
TOOL_CALL_PARSER=qwen3_coder
CALCULATE_KV_SCALES=0
VLLM_TEST_FORCE_FP8_MARLIN=0
VLLM_MARLIN_USE_ATOMIC_ADD=1
ENABLE_PR38361_CANDIDATE=1
ENABLE_QWEN35_CHAT_TEMPLATE_FIX=1
CHAT_TEMPLATE_PATH=/workspace/unsloth.jinja
DEFAULT_CHAT_TEMPLATE_KWARGS={"preserve_thinking":true}
QUANTIZATION=compressed-tensors
LOAD_FORMAT=instanttensor
FLASHINFER_DISABLE_VERSION_CHECK=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
VLLM_HTTP_TIMEOUT_KEEP_ALIVE=600
VLLM_TUNED_CONFIG_FOLDER=/workspace/moe-configs
OPTIMIZATION_LEVEL=3
PERFORMANCE_MODE=throughput
OVERRIDE_GENERATION_CONFIG={"temperature":0.6,"top_p":0.95,"top_k":20,"min_p":0.0,"presence_penalty":1.1,"repetition_penalty":1.01}
SPECULATIVE_CONFIG={"method":"mtp","num_speculative_tokens":3}
HF_TOKEN=
VLLM_API_KEY=

ENABLE_QWEN3CODER_ARG_FILTER=1
ENABLE_TOOLCALL_SANITIZER=1
