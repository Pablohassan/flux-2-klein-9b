# Production override used during the 2026-04-25 multi-day RedHat NVFP4 trial.
# Keep the public upstream model name stable so the router and clients do not
# need to change while the backend model changes.

CONTAINER_NAME=vllm_qwen_chat
SERVED_MODEL_NAME=qwen35a3b-chat
VLLM_BIND_HOST=0.0.0.0
VLLM_PORT=18000
INTERNAL_VLLM_PORT=18055

